{
  "name": "hiero-workflow-app",
  "version": "0.1.0",
  "private": true,
  "description": "A reusable, config-driven GitHub App for automating maintainer workflows across the Hiero SDK ecosystem.",
  "main": "src/index.js",
  "scripts": {
    "start": "probot run ./src/index.js",
    "dev": "nodemon --exec npm start",
    "test": "jest",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "setup": "node scripts/setup.js",
    "test:assign": "probot receive -e issue_comment.created -p tests/fixtures/issue_comment.created.assign.json ./src/index.js",
    "test:unassign": "probot receive -e issue_comment.created -p tests/fixtures/issue_comment.created.unassign.json ./src/index.js",
    "test:pr": "probot receive -e pull_request.opened -p tests/fixtures/pull_request.opened.json ./src/index.js",
    "test:pr-sync": "probot receive -e pull_request.synchronize -p tests/fixtures/pull_request.synchronize.json ./src/index.js",
    "test:issue": "probot receive -e issues.opened -p tests/fixtures/issues.opened.json ./src/index.js",
    "test:all-events": "npm run test:assign && npm run test:unassign && npm run test:pr && npm run test:pr-sync && npm run test:issue"
  },
  "keywords": [
    "hiero",
    "github-app",
    "probot",
    "automation",
    "maintainer-tools"
  ],
  "author": "cheese-cakee",
  "license": "Apache-2.0",
  "dependencies": {
    "ajv": "^8.17.1",
    "js-yaml": "^4.1.0",
    "probot": "^13.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "nock": "^13.5.4",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
